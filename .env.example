# ============================================
# CAÑAS - Configuración
# ============================================
# Copia este archivo a .env y completa los valores.

# Modo desarrollo (local, SQLite)
# DEBUG=true
# DATABASE_URL=

# Modo producción (Supabase PostgreSQL)
# Ve a Supabase → Project Settings → Database → Connection string
# Copia la URL: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DEBUG=false
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxx.supabase.co:5432/postgres

# Clave secreta para JWT (genera una segura)
# En Mac: openssl rand -hex 32
SECRET_KEY=cambiar-por-una-clave-segura-de-32-caracteres

# Opcional: Supabase Auth (solo si quieres usar Supabase Auth)
# SUPABASE_URL=https://tu-proyecto.supabase.co
# SUPABASE_SERVICE_KEY=tu-service-role-key
# SUPABASE_ANON_KEY=tu-anon-key
